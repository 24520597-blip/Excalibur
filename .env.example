# Excalibur Configuration
# Copy this file to .env if you want to customize settings

# =============================================================================
# Claude Configuration
# =============================================================================
# Claude Code manages its own API configuration.
# Configure with: claude config (inside container)

# Optional: Claude model to use
# Options: claude-sonnet-4-5-20250929, claude-opus-4-20250514
LLM_MODEL=claude-sonnet-4-5-20250929

# Select the direct Gemini API backend:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=your-gemini-api-key
# For a Vertex AI Express Mode API key:
# GEMINI_API_MODE=vertex
# Standard Vertex AI uses ADC plus GOOGLE_CLOUD_PROJECT and GOOGLE_CLOUD_LOCATION.
# GOOGLE_APPLICATION_CREDENTIALS=/home/pentester/.config/gcloud/application_default_credentials.json

# =============================================================================
# OpenRouter Configuration
# =============================================================================
# Optional: OpenRouter model to use when EXCALIBUR_AUTH_MODE=openrouter
# Options: deepseek/deepseek-chat, deepseek/deepseek-r1, openai/gpt-5.1, google/gemini-3-pro-preview
# OPENROUTER_MODEL=deepseek/deepseek-chat
